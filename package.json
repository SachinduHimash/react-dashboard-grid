{
  "name": "react-dashboard-grid",
  "version": "1.0.2",
  "description": "A flexible, themeable React dashboard library with drag-and-drop layout, a rich widget library, and a fully functional Add Widget modal. Built on top of react-grid-layout, it provides a powerful and customizable solution for building complex dashboards with ease.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SachinduHimash/react-dashboard-grid.git"
  },
  "homepage": "https://github.com/SachinduHimash/react-dashboard-grid#readme",
  "bugs": {
    "url": "https://github.com/SachinduHimash/react-dashboard-grid/issues"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "scripts": {
    "test": "jest",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "pack:install": "npm run build && npm pack",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "deploy-storybook": "gh-pages -d storybook-static"
  },
  "keywords": [
    "react",
    "dashboard",
    "grid",
    "layout",
    "library",
    "widgets",
    "responsive",
    "drag-and-drop",
    "resizable"
  ],
  "author": "Himash Peiris",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-onboarding": "^10.3.4",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
    "@storybook/react-webpack5": "^10.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-grid-layout": "^1.3.6",
    "@types/recharts": "^1.8.29",
    "@types/testing-library__react": "^10.0.1",
    "babel-jest": "^30.3.0",
    "gh-pages": "^6.3.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "parcel": "^2.16.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^1.4.4",
    "rollup": "^4.60.1",
    "rollup-plugin-typescript2": "^0.37.0",
    "storybook": "^10.3.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "dependencies": {
    "react-grid-layout": ">=1.0.0 <2.0.0",
    "recharts": "^3.8.1"
  }
}
